# 火山 ARK 配置
VOLC_ARK_ACCESS_KEY=your_access_key_here
VOLC_ARK_SECRET_KEY=your_secret_key_here

# 图片生成模型
MODEL_IMAGE=ep-20260313143451-x4jb4
# 视频生成模型
MODEL_VIDEO=ep-20260313144025-s75p5
# 代码生成模型
MODEL_CODE=ark-code-latest

# 飞书配置（可选，用于消息推送）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_CHAT_ID=your_feishu_chat_id

# GitHub 配置（可选，用于自动同步）
GITHUB_TOKEN=your_github_token
GITHUB_REPO=zzeqii/oneman-company

# 定时推送配置
PUSH_DAILY_REPORT=true
PUSH_PROGRESS_ALERT=true
